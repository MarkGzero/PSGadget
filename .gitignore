# Ignore the mynotes directory
mynotes\
mynotes/

# PowerShell specific
*.pssc
*.psproj
*.psworkspace

# Test and coverage results  
*.Tests.ps1.xml
coverage.xml
TestResults/

# User data and logs (but keep the structure)
**/.psgadget/logs/*.log
**/.psgadget/config/

# IDE specific
.vscode/settings.json
.vscode/launch.json
.idea/
*.swp
*.swo
*~

# OS specific  
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# Temporary files
*.tmp
*.temp
*.bak

# Module packaging output
*.nupkg
*.zip

# Build/release output folders
out/
dist/
release/

# Debug symbols
*.pdb

# Root-level local data created by Initialize-PsGadgetEnvironment
.psgadget/

# PowerShell script analyzer output
PSScriptAnalyzer*.txt

# Pester coverage output
coverage/

# Backup files
*.backup

# dotnet restore artifacts (lib/nuget-deps.csproj)
lib/obj/

# ---------------------------------------------------------------------------
# Security: credentials, secrets, keys, device data
# ---------------------------------------------------------------------------

# Crypto keys and certificates
*.key
*.pem
*.pfx
*.p12
*.crt
*.cer
*.der

# Environment / secret files
.env
.env.*
*.env
secrets.*
*.secret
*.secrets

# CTF provisioning -- gadget keys must never be committed
ctf_config.json
flag_secret*
gadget_key*

# Local config overrides
*.local.json
config.local.*

# Device registry (contains hardware MAC addresses)
known_devices.txt
