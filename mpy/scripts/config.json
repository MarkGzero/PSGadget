{
    "_comment": "PsGadget ESP-NOW script configuration. Deployed alongside espnow_receiver.py or espnow_transmitter.py as config.json on the device flash.",

    "_receiver_pins": "-- Receiver (wired to FT232H via UART) --",
    "uart_tx_pin":    5,
    "uart_rx_pin":    6,
    "uart_baud":      115200,
    "neopixel_pin":   21,
    "neopixel_count": 1,
    "broadcast_interval_ms": 100,

    "_transmitter_pins": "-- Transmitter (wireless, ESP32-S3 Zero defaults) --",
    "neopixel_power_pin": 38,
    "send_interval_ms":   5000,
    "receiver_poll_ms":   500,

    "_shared": "-- Shared --",
    "ctssid":      "PsGadget-CT",
    "gadget_type": "PsGadget-IO",
    "macfile":     "known_devices.txt",

    "_payload": "-- Transmitter payload: 'telemetry' = auto rgb color; or use a custom string --",
    "payload": "telemetry"
}
